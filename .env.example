NEXT_PUBLIC_WEB3FORMS_KEY=your-access-key-here

# Resend — contact form
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Honto <hello@yourdomain.com>
CONTACT_TO_EMAIL=info@honto.ai

# Resend — AI Readiness onboarding form
ONBOARDING_TO_EMAIL=aumerez@honto.ai

# Authenticated desktop installer downloads (/app-download)
# Server-side only — no NEXT_PUBLIC_ prefix; never exposed to the browser.
# The current version + installer filename are resolved per request from the
# release manifest (src/lib/downloads/manifest.ts); the bucket + channel are
# code constants there. No env vars are needed for the download URL itself.
SITE_ORIGIN=https://honto.ai
BACKEND_URL=

# Installer delivery: by default the public manifest URL is served directly
# (soft gate — anyone with the URL can download). To upgrade to a real
# boundary, provision a private honto-installers bucket and set the R2
# credentials below; the route then mints 5-min presigned URLs (spec §4.6)
# for the same manifest-resolved filename. Leave empty otherwise.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=honto-installers
R2_PUBLIC_ENDPOINT=https://downloads.honto.ai

# Optional: when set, /api/downloads emits a fire-and-forget audit POST.
AUDIT_LOG_URL=
AUDIT_LOG_TOKEN=
