NEXT_PUBLIC_WEB3FORMS_KEY=your-access-key-here

# Resend — contact form
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Honto <hello@yourdomain.com>
CONTACT_TO_EMAIL=info@honto.ai

# Resend — AI Readiness onboarding form
ONBOARDING_TO_EMAIL=aumerez@honto.ai

# Authenticated desktop installer downloads (/app-download)
# Server-side only — no NEXT_PUBLIC_ prefix; never exposed to the browser.
# The installer version + filename layout are constants in
# src/lib/downloads/platforms.ts (bumped per release in code).
SITE_ORIGIN=https://honto.ai
BACKEND_URL=

# Installer storage. Choose ONE mode:
#
# Mode 1 — public bucket (dev/testing). Anyone who knows the URL can
#   download; the cookie gate is a soft UX gate, not a security boundary.
#   Set ONLY R2_PUBLIC_BASE_URL; leave the credential vars empty.
#R2_PUBLIC_BASE_URL=https://pub-XXXX.r2.dev
#
# Mode 2 — private bucket + 5-min presigned URLs (production, spec §4.6).
#   Provide R2 credentials; leave R2_PUBLIC_BASE_URL empty.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Defaults to honto-updates (current beta channel layout). Change to
# honto-installers once the dedicated private bucket is provisioned.
R2_BUCKET=honto-updates
R2_PUBLIC_ENDPOINT=https://downloads.honto.ai

# Optional: when set, /api/downloads emits a fire-and-forget audit POST.
AUDIT_LOG_URL=
AUDIT_LOG_TOKEN=
