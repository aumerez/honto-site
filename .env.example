NEXT_PUBLIC_WEB3FORMS_KEY=your-access-key-here

# Resend — contact form
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Honto <hello@yourdomain.com>
CONTACT_TO_EMAIL=info@honto.ai

# Resend — AI Readiness onboarding form
ONBOARDING_TO_EMAIL=aumerez@honto.ai

# Authenticated desktop installer downloads (/app-download)
# Server-side only — no NEXT_PUBLIC_ prefix; never exposed to the browser.
SITE_ORIGIN=https://honto.ai
BACKEND_URL=

# Installer delivery: the bucket is private. Both the release manifest (which
# yields the current version + filename) and the installer itself are read from
# R2_BUCKET with these credentials; the route then mints a 5-min presigned URL
# (spec §4.6). Without these vars, downloads report unavailable (503) — there
# is no public fallback. The channel + key prefix are code constants
# (src/lib/downloads/{manifest,platforms}.ts).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=honto-installers
# Optional: custom domain bound to the bucket, so presigned URLs use it instead
# of the raw <account>.r2.cloudflarestorage.com host. Leave empty otherwise.
R2_PUBLIC_ENDPOINT=https://downloads.honto.ai

# Optional: when set, /api/downloads emits a fire-and-forget audit POST.
AUDIT_LOG_URL=
AUDIT_LOG_TOKEN=
